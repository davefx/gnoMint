<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="preferences_dialog">
    <property name="margin-start">5</property>
    <property name="margin-end">5</property>
    <property name="margin-top">5</property>
    <property name="margin-bottom">5</property>
    <property name="title" translatable="1">General Preferences - gnoMint</property>
    <property name="resizable">0</property>
    <property name="modal">1</property>
    <child>
      <object class="GtkBox" id="dialog-vbox19">
        <property name="orientation">vertical</property>
        <property name="spacing">2</property>
        <child>
          <object class="GtkNotebook" id="notebook1">
            <property name="focusable">1</property>
            <child>
              <object class="GtkNotebookPage">
                <property name="child">
                  <object class="GtkBox" id="vbox7">
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="GtkCheckButton" id="gnomekeyring_export_check">
                        <property name="label" translatable="1">Automatically export created certificates to
Gnome-keyring certificate store</property>
                        <property name="focusable">1</property>
                        <property name="use_underline">1</property>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="tab">
                  <object class="GtkLabel" id="label46">
                    <property name="label" translatable="1">Export options</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <property name="margin-top">12</property>
            <child>
              <object class="GtkButton" id="preferences_ok_button">
                <property name="label" translatable="yes">_OK</property>
                <property name="use-underline">1</property>
                <property name="focusable">1</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="ok">preferences_ok_button</action-widget>
    </action-widgets>
  </object>
</interface>
