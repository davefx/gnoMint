<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkBox" id="san_manager_vbox">
    <property name="orientation">vertical</property>
    <property name="spacing">6</property>
    <child>
      <object class="GtkScrolledWindow" id="scrolled_window">
        <property name="vexpand">1</property>
        <property name="focusable">1</property>
        <property name="height_request">120</property>
        <property name="child">
          <object class="GtkTreeView" id="san_treeview">
            <property name="focusable">1</property>
            <property name="model">san_list_model</property>
            <property name="enable_search">0</property>
            <child>
              <object class="GtkTreeViewColumn" id="type_column">
                <property name="title" translatable="1">Type</property>
                <property name="sizing">autosize</property>
                <child>
                  <object class="GtkCellRendererText" id="type_cell"/>
                  <attributes>
                    <attribute name="text">0</attribute>
                  </attributes>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkTreeViewColumn" id="value_column">
                <property name="title" translatable="1">Value</property>
                <property name="sizing">autosize</property>
                <property name="expand">1</property>
                <child>
                  <object class="GtkCellRendererText" id="value_cell"/>
                  <attributes>
                    <attribute name="text">1</attribute>
                  </attributes>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="button_box">
        <property name="valign">center</property>
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="spacing">6</property>
        <child>
          <object class="GtkButton" id="add_button">
            <property name="label" translatable="1">_Add</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="edit_button">
            <property name="label" translatable="1">_Edit</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
            <property name="sensitive">0</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="remove_button">
            <property name="label" translatable="1">_Remove</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
            <property name="sensitive">0</property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkListStore" id="san_list_model">
    <columns>
      <column type="gchararray"/>
      <column type="gchararray"/>
    </columns>
  </object>
</interface>
