<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkWindow" id="csr_properties_dialog">
    <property name="title" translatable="1">CSR properties - gnoMint</property>
    <property name="modal">1</property>
    <child>
      <placeholder/>
    </child>
    <property name="child">
      <object class="GtkBox" id="vbox21">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkNotebook" id="notebook4">
            <property name="margin-start">5</property>
            <property name="margin-end">5</property>
            <property name="margin-top">5</property>
            <property name="margin-bottom">5</property>
            <property name="show_tabs">0</property>
            <property name="show_border">0</property>
            <child>
              <object class="GtkNotebookPage">
                <property name="tab_fill">False</property>
                <property name="child">
                  <object class="GtkBox" id="vbox22">
            <property name="margin-start">5</property>
            <property name="margin-end">5</property>
            <property name="margin-top">5</property>
            <property name="margin-bottom">5</property>
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="GtkBox" id="vboxCertCapabilities2">
            <property name="margin-start">5</property>
            <property name="margin-end">5</property>
            <property name="margin-top">5</property>
            <property name="margin-bottom">5</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">5</property>
