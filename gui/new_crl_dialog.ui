<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="new_crl_dialog">
            <property name="margin-start">5</property>
            <property name="margin-end">5</property>
            <property name="margin-top">5</property>
            <property name="margin-bottom">5</property>
    <property name="title" translatable="1">New CRL - gnoMint</property>
    <child>
      <placeholder/>
    </child>
    <child internal-child="content_area">
      <object class="GtkBox" id="dialog-vbox21">
        <property name="orientation">vertical</property>
        <property name="spacing">11</property>
        <child>
          <object class="GtkLabel" id="label50">
            <property name="valign">center</property>
            <property name="label" translatable="1">&lt;big&gt;&lt;b&gt;New Certificate Revocation List&lt;/b&gt;&lt;/big&gt;</property>
            <property name="use_markup">1</property>
            <property name="xalign">0</property>
            <property name="yalign">0</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="label51">
            <property name="valign">center</property>
            <property name="label" translatable="1">Please, select the CA for which a Certificate 
Revocation List is going to be created:</property>
            <property name="xalign">0</property>
          </object>
        </child>
        <child>
          <object class="GtkScrolledWindow" id="scrolledwindow2">
            <property name="vexpand">1</property>
            <property name="focusable">1</property>
            <property name="child">
              <object class="GtkColumnView" id="crl_ca_treeview">
                <property name="focusable">1</property>
                <property name="show-column-separators">0</property>
                <property name="show-row-separators">0</property>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="0">button22</action-widget>
      <action-widget response="0">crl_ok_button</action-widget>
    </action-widgets>
    <child internal-child="action_area">
      <object class="GtkBox" id="dialog-action_area21">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <child>
          <object class="GtkButton" id="button22">
            <property name="label">gtk-cancel</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="crl_ok_button">
            <property name="label">gtk-ok</property>
            <property name="sensitive">0</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
