<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="get_db_password_dialog">
    <property name="title" translatable="1">Enter password - gnoMint</property>
    <property name="modal">1</property>
    <child>
      <object class="GtkBox" id="dialog-vbox13">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox" id="vbox24">
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-top">20</property>
            <property name="margin-bottom">20</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkLabel" id="get_passwd_msg_label">
                <property name="valign">center</property>
                <property name="label" translatable="1">This action requires using one or more private keys saved in the CA database.

Please insert the database password.</property>
                <property name="use_markup">1</property>
                <property name="justify">fill</property>
                <property name="wrap">1</property>
                <property name="width_chars">40</property>
                <property name="xalign">0</property>
                <property name="yalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="pwd_hbox">
                <child>
                  <object class="GtkImage" id="image16">
                    <property name="icon_name">dialog-password</property>
                    <property name="icon_size">normal</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="password_message2">
                    <property name="label" translatable="1">Password:</property>
                    <property name="use_markup">1</property>
                    <property name="xalign">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="cadb_password_entry">
                    <property name="focusable">1</property>
                    <property name="visibility">0</property>
                    <property name="activates_default">1</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="remember_password_checkbutton">
                <property name="valign">center</property>
                <property name="label" translatable="1">Remember this password during this gnoMint session</property>
                <property name="focusable">1</property>
                <property name="focus_on_click">0</property>
              </object>
            </child>
          </object>
        </child>
              <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <property name="margin-top">12</property>
            <child>
              <object class="GtkButton" id="button11">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">Cancel</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="cadb_password_dialog_ok_button">
                <property name="focusable">1</property>
                <property name="label" translatable="yes">OK</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="cancel">button11</action-widget>
      <action-widget response="1">cadb_password_dialog_ok_button</action-widget>
    </action-widgets>
</object>
</interface>
