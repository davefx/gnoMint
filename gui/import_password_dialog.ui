<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="import_password_dialog">
    <property name="title" translatable="1">Enter password - gnoMint</property>
    <property name="modal">1</property>
    <child>
      <object class="GtkBox" id="dialog-vbox16">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox" id="vbox8">
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-top">20</property>
            <property name="margin-bottom">20</property>
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkLabel" id="get_passwd_msg_label1">
                <property name="valign">center</property>
                <property name="label" translatable="1">The whole selected file, or some of its elements, seems to
be cyphered using a password or passphrase.

For importing the file into gnoMint database, you must
provide an appropiate password.</property>
                <property name="use_markup">1</property>
                <property name="justify">fill</property>
                <property name="wrap">1</property>
                <property name="width_chars">40</property>
                <property name="xalign">0</property>
                <property name="yalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label52">
                <property name="margin_top">8</property>
                <property name="margin_bottom">8</property>
                <property name="label" translatable="1">&lt;small&gt;&lt;i&gt;The part that is being imported has the description:&lt;/i&gt;&lt;/small&gt;</property>
                <property name="use_markup">1</property>
                <property name="use_underline">1</property>
                <property name="justify">right</property>
                <property name="xalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="import_crypted_part_description">
                <property name="margin-start">15</property>
                <property name="margin-end">15</property>
                <property name="label" translatable="1">&lt;small&gt;&lt;i&gt;#Description#&lt;/i&gt;&lt;/small&gt;</property>
                <property name="use_markup">1</property>
                <property name="use_underline">1</property>
                <property name="justify">right</property>
                <property name="xalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="pwd_hbox1">
                <child>
                  <object class="GtkImage" id="image17">
                    <property name="icon_name">dialog-password</property>
                    <property name="icon_size">normal</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="password_message1">
                    <property name="label" translatable="1">Password:</property>
                    <property name="use_markup">1</property>
                    <property name="xalign">1</property>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="import_password_entry">
                    <property name="focusable">1</property>
                    <property name="visibility">0</property>
                    <property name="activates_default">1</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
              <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <property name="margin-top">12</property>

          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="cancel">button21</action-widget>
      <action-widget response="1">import_password_dialog_ok_button1</action-widget>
    </action-widgets>
</object>
</interface>
