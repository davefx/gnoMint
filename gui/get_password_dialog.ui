<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="get_password_dialog">
    <property name="title" translatable="1">Enter password - gnoMint</property>
    <property name="modal">1</property>
    <child>
      <placeholder/>
    </child>
    <child internal-child="content_area">
      <object class="GtkBox" id="dialog-vbox12">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox" id="vbox17">
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkLabel" id="info_message">
                <property name="label" translatable="1">Please, enter password</property>
                <property name="use_markup">1</property>
                <property name="wrap">1</property>
                <property name="xalign">0</property>
                <property name="yalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkGrid" id="table3">
                <child>
                  <object class="GtkEntry" id="confirm_entry">
                    <property name="focusable">1</property>
                    <property name="visibility">0</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkEntry" id="password_entry">
                    <property name="focusable">1</property>
                    <property name="visibility">0</property>
                    <property name="activates_default">1</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="confirm_message">
                    <property name="label" translatable="1">Password (confirm):</property>
                    <property name="use_markup">1</property>
                    <property name="xalign">0</property>
                    <property name="yalign">0</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="password_message">
                    <property name="label" translatable="1">Password:</property>
                    <property name="use_markup">1</property>
                    <property name="xalign">0</property>
                    <property name="yalign">0</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="row">0</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="0">button10</action-widget>
      <action-widget response="1">password_dialog_ok_button</action-widget>
    </action-widgets>
    <child internal-child="action_area">
      <object class="GtkBox" id="dialog-action_area12">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <child>
          <object class="GtkButton" id="button10">
            <property name="label">gtk-cancel</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="password_dialog_ok_button">
            <property name="label">gtk-ok</property>
            <property name="sensitive">0</property>
            <property name="focusable">1</property>
            <property name="receives_default">1</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
