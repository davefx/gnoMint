<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkDialog" id="get_pkey_dialog">
            <property name="margin-start">5</property>
            <property name="margin-end">5</property>
            <property name="margin-top">5</property>
            <property name="margin-bottom">5</property>
    <property name="title" translatable="1">Choose private key file. gnoMint</property>
    <property name="modal">1</property>
    <child>
      <object class="GtkBox" id="dialog-vbox20">
        <property name="orientation">vertical</property>
        <property name="spacing">2</property>
        <child>
          <object class="GtkBox" id="vbox18">
            <property name="orientation">vertical</property>
            <property name="spacing">20</property>
            <child>
              <object class="GtkLabel" id="label28">
                <property name="valign">center</property>
                <property name="label" translatable="1">&lt;big&gt;Choose private key file&lt;/big&gt;

For doing the selected operation, you must provide the
file where resides the private key corresponding to the
certificate:</property>
                <property name="use_markup">1</property>
                <property name="wrap">1</property>
                <property name="wrap_mode">word-char</property>
                <property name="width_chars">40</property>
                <property name="xalign">0</property>
                <property name="yalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="cert_dn_label">
                <property name="label" translatable="1">Certificate DN</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label31">
                <property name="valign">center</property>
                <property name="label" translatable="1">Please, choose the file:</property>
                <property name="use_markup">1</property>
                <property name="wrap">1</property>
                <property name="wrap_mode">word-char</property>
                <property name="width_chars">40</property>
                <property name="xalign">0</property>
                <property name="yalign">0</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="pkey_filechooser">
                <property name="valign">center</property>
                <property name="visible">True</property>
                <property name="can_focus">False</property>
              </object>
            </child>
            <child>
              <object class="GtkCheckButton" id="save_filename_checkbutton">
                <property name="valign">center</property>
                <property name="label" translatable="1">_Save filename in the database for automatic loading</property>
                <property name="focusable">1</property>
                <property name="use_underline">1</property>
              </object>
            </child>
          </object>
        </child>
              <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <property name="margin-top">12</property>

          </object>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="cancel">button15</action-widget>
      <action-widget response="1">button7</action-widget>
    </action-widgets>
</object>
</interface>
